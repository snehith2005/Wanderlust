<% layout('/layouts/boilerplate') %>
    <!-- <h3>All Listings</h3>
    <form method="GET" action="/listings/new">
      <button class="btn btn-dark mb-3">Create New Listing</button>
    </form> -->
    <style>
      .filters{
        display: flex;
        flex-wrap: wrap;
        
      }
      .filter{
        margin-right: 2rem;
        text-align: center;
        opacity: 0.7;
        cursor: pointer;
        margin-top: 2rem;
      }
      .filter:hover{
        opacity: 1;
      }
      .filter p{
        font-size: 0.8rem;
      }
      .switches{
        border: 2px solid black;
        border-radius: 1rem;
        height: 3rem;
        padding: 0.7rem;
      }
      .text-info{
        display: none;
      }
      .switches{
        margin-top: 1.5rem;
        margin-left: 1rem;
      }
    </style>
    <div class="filters ">
      <div class="filter">
        <div><i class="fa-solid fa-snowflake"></i></div>
        <p>arctic</p>
      </div>
      <div class="filter">
       <div><i class="fa-solid fa-fire"></i></div>
        <p>camping</p>
      </div>
      <div class="filter">
        <div><i class="fa-solid fa-house-chimney"></i></div>
        <p>homes</p>
      </div>
      <div class="filter">
        <div><i class="fa-solid fa-fan"></i></div>
        <p>Cool place</p>
      </div>
      
      <div class="filter">
        <div><i class="fa-solid fa-utensils"></i></div>
        <p>Food plcaes</p>
      </div>
      <div class="filter">
       <div> <i class="fa-solid fa-hotel"></i></div>
        <p>Hotel</p>
      </div>
      <div class="filter">
        <div><i class="fa-solid fa-mountain-city"></i></div>
        <p>City</p>
      </div>
      <div class="filter">
       <div> <i class="fa-solid fa-warehouse"></i></div>
        <p>Warehouse</p>
      </div>
      <div class="filter">
       <div> <i class="fa-solid fa-person-swimming"></i></div>
        <p>Swimming pool</p>
      </div>
      <div class="filter">
       <div> <i class="fa-solid fa-dumbbell"></i></div>
        <p>Gym</p>
      </div>
      <div class="filter">
        <div><i class="fa-solid fa-baseball-bat-ball"></i></div>
        <p>Baseball</p>
      </div>
      <div class="switches">
        <div class="form-check-reverse form-switch">
          <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault">
          <label class="form-check-label" for="flexSwitchCheckDefault">Display total after taxes</label>
        </div>
      </div>
    </div>
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-2">
  <% if (!search_inp) { %>
    <% for (let listing of allListings) { %>
      <a href="/listings/<%= listing.id %>" class="listing-link">
        <div class="card col listing-card" style="width: 20rem;">
          <img class="card-img-top" src="<%= listing.image.url %>" style="height: 20rem !important;">
          <div class="card-img-overlay">hello</div>
          <div class="card-body">
            <p class="card-text">
              <b><%= listing.title %></b><br>
              &#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") : "Not Available" %> <i class="text-info">+18% GST</i><br>
            </p>
          </div>
        </div>
      </a>
    <% } %>
  <% } else { %>
    <% for (let listing of allListings) { %>
      <a href="/listings/<%= listing.id %>" class="listing-link">
        <div class="card col listing-card" style="width: 20rem;">
          <img class="card-img-top" src="<%= listing.image.url %>" style="height: 20rem !important;">
          <div class="card-img-overlay">hello</div>
          <div class="card-body">
            <p class="card-text">
              <b><%= listing.title %></b><br>
              &#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") : "Not Available" %> <i class="text-info">+18% GST</i><br>
            </p>
          </div>
        </div>
      </a>
    <% } %>
  <% } %>
</div>

    <script>
      let switchtoggle=document.getElementById("flexSwitchCheckDefault")
      switchtoggle.addEventListener("click",()=>{
        let tax_info=document.getElementsByClassName("text-info")
      
        for (info of tax_info){
          if(info.style.display!="inline"){
            info.style.display="inline"
          }
          else{
            info.style.display="none"
          }
        }
      })

      
    </script>
   
